generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  password    String?
  image       String?
  bio         String?
  timezone    String?  @default("Asia/Tokyo")
  joinedAt    DateTime @default(now())
  preferences String?  // JSON string: theme, notifications, language

  habits         Habit[]
  habitLogs      HabitLog[]
  moodLogs       MoodLog[]
  journalEntries JournalEntry[]
  gratitudeLogs  GratitudeLog[]
  waterLogs      WaterLog[]
  sleepLogs      SleepLog[]
  energyLogs     EnergyLog[]
  routineLogs    RoutineLog[]
  goals          Goal[]
  focusSessions  FocusSession[]
  screenTimeLogs ScreenTimeLog[]
  appTimers      AppTimer[]
  selfCareLogs   SelfCareLog[]
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Habit {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String?
  color     String?
  order     Int      @default(0)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]
}

model HabitLog {
  id        String  @id @default(cuid())
  userId    String
  habitId   String
  date      String // "2026-03-15"
  completed Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  mood      Int // 0=Peaceful, 1=Happy, 2=Good, 3=Neutral, 4=Low, 5=Stressed
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  date      String
  content   String
  prompt    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model GratitudeLog {
  id     String  @id @default(cuid())
  userId String
  date   String
  entry1 String?
  entry2 String?
  entry3 String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model WaterLog {
  id      String @id @default(cuid())
  userId  String
  date    String
  glasses Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model SleepLog {
  id         String  @id @default(cuid())
  userId     String
  date       String
  hours      Float?
  quality    Int? // 1-5
  restedness Int? // 1-5
  bedtime    String? // "22:30"
  wakeTime   String? // "06:00"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model EnergyLog {
  id       String @id @default(cuid())
  userId   String
  date     String
  energy   Int? // 1-5
  stress   Int? // 1-5
  calm     Int? // 1-5
  physical Int? // 1-5

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model RoutineLog {
  id        String  @id @default(cuid())
  userId    String
  date      String
  type      String // "morning" | "evening"
  item      String
  completed Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type, item])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  month     String // "2026-03"
  text      String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FocusSession {
  id        String   @id @default(cuid())
  userId    String
  date      String
  duration  Int // minutes
  type      String // "focus" | "break"
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScreenTimeLog {
  id            String @id @default(cuid())
  userId        String
  date          String
  appName       String
  minutesUsed   Int    @default(0)
  timesUnlocked Int    @default(0)
  mathSolved    Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, appName])
}

model AppTimer {
  id            String  @id @default(cuid())
  userId        String
  appName       String
  dailyLimitMin Int     @default(30)
  isActive      Boolean @default(true)
  iconUrl       String?
  color         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appName])
}

model SelfCareLog {
  id        String  @id @default(cuid())
  userId    String
  date      String
  activity  String
  completed Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, activity])
}
